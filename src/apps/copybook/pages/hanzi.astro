---
import CopybookLayout from '@copybook/layout.astro'
import CanvasPreview from '@copybook/components/CanvasPreview.tsx'
import ControlPanel from '@copybook/components/ControlPanel.tsx'
---

<CopybookLayout title="汉字字帖">
  <div class="flex h-full overflow-hidden">
    <aside class="p-4 border-r border-gray-200 w-[300px] overflow-y-auto">
      <ControlPanel client:only="react" />
    </aside>
    <CanvasPreview client:only="react" />
  </div>
</CopybookLayout>
