---
import { WordLearner } from '@english/components/WordLearner'
import EnglishLayout from '@english/layout.astro'

const textbookId = Astro.url.searchParams.get('textbookId')
const unitNumber = Astro.url.searchParams.get('unitNumber')

// 无参数时重定向到 gallery
if (!textbookId || !unitNumber) {
  return Astro.redirect('/english/gallery')
}
---

<EnglishLayout title="单词学习">
  <WordLearner
    client:load
    initialTextbookId={Number(textbookId)}
    initialUnitNumber={Number(unitNumber)}
  />
</EnglishLayout>
