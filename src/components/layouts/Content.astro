---
import { LayoutConfig } from '@/config/layout.config'
import { toPxString } from '@/shared/common/px'

interface Props {
  paddingX?: number
  paddingY?: number
  spaceX?: number
  spaceY?: number
}

const { paddingX = 20, paddingY = 20, spaceX, spaceY } = Astro.props
---

<section
  id="content"
  style={{
    padding: `${toPxString(paddingY)} ${toPxString(paddingX)}`,
    minHeight: `calc(100vh - ${toPxString(LayoutConfig.header.height + LayoutConfig.footer.height)})`,
    columnGap: spaceX ? `${spaceX * 0.25}rem` : undefined,
    rowGap: spaceY ? `${spaceY * 0.25}rem` : undefined,
  }}
>
  <slot />
</section>
