{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "preserve",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@copybook/*": [
        "./src/apps/copybook/*"
      ],
      "@workbook/*": [
        "./src/apps/workbook/*"
      ],
      "@wordbook/*": [
        "./src/apps/wordbook/*"
      ],
      "@database/*": [
        "./src/database/*"
      ]
    }
  }
}
