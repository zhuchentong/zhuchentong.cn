{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "preserve",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@copybook/*": [
        "./src/apps/copybook/*"
      ],
      "@workbook/*": [
        "./src/apps/workbook/*"
      ],
      "@english/*": [
        "./src/apps/english/*"
      ],
      "@chinese/*": [
        "./src/apps/chinese/*"
      ],
      "@history/*": [
        "./src/apps/history/*"
      ],
      "@database/*": [
        "./src/database/*"
      ]
    }
  }
}
